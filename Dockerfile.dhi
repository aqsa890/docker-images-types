# ────────────────
# 1. Build Stage
# ────────────────
FROM node:22-slim AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install --omit=dev

COPY . .

# ────────────────
# 2. Hardened Runtime (Distroless)
# ────────────────
FROM gcr.io/distroless/nodejs22-debian12

WORKDIR /app

COPY --from=builder /app .

ENV IMAGE_TYPE="Hardened (Distroless)"

EXPOSE 3000

CMD ["app.js"]